{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "metrics": {
    "metrics_collected": {
      "cpu": {
        "measurement": [
          "cpu_usage_active"
        ],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "mem": {
        "measurement": [
          "mem_used_percent"
        ],
        "metrics_collection_interval": 60
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/ubuntu/ce-project-2-instrumented-monitored-service/app/application.log",
            "log_group_name": "/aws/application/api",
            "log_stream_name": "{instance_id}-app",
            "timezone": "UTC",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "retention_in_days": 5
          },
          {
            "file_path": "/var/log/syslog",
            "log_group_name": "/aws/system/syslog",
            "log_stream_name": "{instance_id}-syslog",
            "timezone": "UTC",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "retention_in_days": 5
          }
        ]
      }
    }
  }
}